#!/usr/bin/env python3
import base64
import json
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


BASE_URL = {{ obsidian_base_url | to_json }}
ADMIN_USER = {{ couchdb_admin_user | to_json }}
ADMIN_PASS = {{ couchdb_admin_password | to_json }}
COUCHDB_VAULTS = {{ couchdb_vaults | to_json }}


def build_request(path: str, *, method: str = "GET", payload: dict | None = None) -> urllib.request.Request:
    url = urllib.parse.urljoin(BASE_URL.rstrip("/") + "/", path.lstrip("/"))
    data = None
    headers = {
        "Authorization": "Basic " + base64.b64encode(f"{ADMIN_USER}:{ADMIN_PASS}".encode("utf-8")).decode("ascii"),
    }
    if payload is not None:
        data = json.dumps(payload).encode("utf-8")
        headers["Content-Type"] = "application/json"
    return urllib.request.Request(url, data=data, headers=headers, method=method)


def request_json(
    path: str,
    *,
    method: str = "GET",
    payload: dict | None = None,
    allowed_statuses: set[int] | None = None,
) -> tuple[int, dict | None]:
    allowed = allowed_statuses or {200}
    request = build_request(path, method=method, payload=payload)
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            status = response.getcode()
            body = response.read().decode("utf-8").strip()
    except urllib.error.HTTPError as exc:
        status = exc.code
        body = exc.read().decode("utf-8").strip()
        if status not in allowed:
            raise
    if status not in allowed:
        raise RuntimeError(f"Unexpected HTTP status {status} for {method} {path}")
    if not body:
        return status, None
    try:
        return status, json.loads(body)
    except json.JSONDecodeError:
        return status, None


def wait_for_couchdb() -> None:
    for _ in range(30):
        try:
            status, payload = request_json("/_up", allowed_statuses={200})
        except Exception:
            time.sleep(2)
            continue
        if status == 200 and isinstance(payload, dict) and payload.get("status") == "ok":
            return
        time.sleep(2)
    raise RuntimeError("CouchDB did not become ready before timeout.")


def upsert_user(username: str, password: str) -> None:
    user_doc_path = "/_users/org.couchdb.user:" + urllib.parse.quote(username, safe="")
    status, payload = request_json(user_doc_path, allowed_statuses={200, 404})
    user_doc = {
        "_id": f"org.couchdb.user:{username}",
        "name": username,
        "password": password,
        "roles": [],
        "type": "user",
    }
    if status == 200 and isinstance(payload, dict) and payload.get("_rev"):
        user_doc["_rev"] = payload["_rev"]
    request_json(user_doc_path, method="PUT", payload=user_doc, allowed_statuses={201, 202})


def ensure_database(db_name: str) -> None:
    request_json("/" + urllib.parse.quote(db_name, safe=""), method="PUT", allowed_statuses={201, 412})


def apply_security(db_name: str, username: str) -> None:
    payload = {
        "admins": {"names": [username], "roles": []},
        "members": {"names": [username], "roles": []},
    }
    path = "/" + urllib.parse.quote(db_name, safe="") + "/_security"
    request_json(path, method="PUT", payload=payload, allowed_statuses={200, 201})


def main() -> int:
    wait_for_couchdb()
    for vault in COUCHDB_VAULTS:
        db_name = vault["db_name"]
        username = vault["user"]
        password = vault["password"]
        upsert_user(username, password)
        ensure_database(db_name)
        apply_security(db_name, username)
        print(f"Configured CouchDB vault {vault['name']} ({db_name})", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
