#!/usr/bin/env bash
set -euo pipefail
TARGET_NAME="${1:-}"
JOB_NAME="${2:-}"

log() { printf '[restic-maintain] %s\n' "$*"; }
err() { printf '[restic-maintain][ERROR] %s\n' "$*" >&2; }

if [[ -z "$TARGET_NAME" || -z "$JOB_NAME" ]]; then
  err "Usage: $0 <target> <job>"
  exit 64
fi

TARGET_ENV="{{ restic_targets_dir }}/${TARGET_NAME}.env"
JOB_CONFIG="{{ restic_jobs_dir }}/${JOB_NAME}.sh"

[[ -r "$TARGET_ENV" ]] || { err "Missing target env: $TARGET_ENV"; exit 66; }
[[ -r "$JOB_CONFIG" ]] || { err "Missing job config: $JOB_CONFIG"; exit 66; }

# shellcheck disable=SC1090
source "$TARGET_ENV"
# shellcheck disable=SC1090
source "$JOB_CONFIG"

RESTIC_ARGS=()
if [[ -n "${RESTIC_SFTP_COMMAND:-}" ]]; then
  RESTIC_ARGS+=(-o "sftp.command=${RESTIC_SFTP_COMMAND}")
fi

HOST_LABEL="${RESTIC_HOST_LABEL:-$(hostname -f 2>/dev/null || hostname -s)}"

log "Applying retention policy for job ${JOB_NAME} on target ${TARGET_NAME}"
restic "${RESTIC_ARGS[@]}" forget --prune \
  --host "$HOST_LABEL" \
  --tag "job:${JOB_NAME}" \
  --group-by host,tags \
  --keep-daily "${RETENTION_DAILY}" \
  --keep-weekly "${RETENTION_WEEKLY}" \
  --keep-monthly "${RETENTION_MONTHLY}"

log "Current snapshots for job ${JOB_NAME} on target ${TARGET_NAME}:"
restic "${RESTIC_ARGS[@]}" snapshots --host "$HOST_LABEL" --tag "job:${JOB_NAME}" --compact
