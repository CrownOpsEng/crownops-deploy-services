#!/usr/bin/env bash
set -euo pipefail
TARGET="${1:-primary}"
case "$TARGET" in
  primary)
    source /opt/crownops-backup/restic-primary.env
    ;;
  secondary)
    source /opt/crownops-backup/restic-secondary.env
    ;;
  *)
    echo "Usage: $0 [primary|secondary]" >&2
    exit 1
    ;;
esac

restic snapshots >/dev/null 2>&1 || restic init
restic backup {% for p in restic_backup_paths %} {{ p }}{% endfor %}
