#!/usr/bin/env bash
set -euo pipefail
TARGET="${1:-primary}"
case "$TARGET" in
  primary)
    source /opt/crownops-backup/restic-primary.env
    ;;
  secondary)
    source /opt/crownops-backup/restic-secondary.env
    ;;
  *)
    echo "Usage: $0 [primary|secondary]" >&2
    exit 1
    ;;
esac

RESTIC_ARGS=()
if [[ -n "${RESTIC_SFTP_COMMAND:-}" ]]; then
  RESTIC_ARGS+=(-o "sftp.command=${RESTIC_SFTP_COMMAND}")
fi

restic "${RESTIC_ARGS[@]}" forget --prune \
  --keep-daily {{ restic_retention_daily }} \
  --keep-weekly {{ restic_retention_weekly }} \
  --keep-monthly {{ restic_retention_monthly }}
